# Application
APP_NAME=AI Prompt Lab
DEBUG=true

# Database
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/prompt_lab?charset=utf8mb4

# JWT
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-with-a-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# API key encryption
# Generate ENCRYPTION_MASTER_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Generate ENCRYPTION_SALT with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(16)).decode())"
ENCRYPTION_MASTER_KEY=replace-with-a-random-encryption-master-key
ENCRYPTION_SALT=replace-with-a-random-base64-salt

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:5173,http://localhost:3000

# Optional default AI provider, used when no user/global AI config exists
ENABLE_DEFAULT_AI=false
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-3.5-turbo
DEFAULT_AI_API_KEY=
DEFAULT_AI_BASE_URL=https://api.openai.com/v1
